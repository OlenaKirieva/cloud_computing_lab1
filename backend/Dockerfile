# Використовуємо легку версію Python
FROM python:3.12-slim

# Встановлюємо робочу директорію всередині контейнера
WORKDIR /app

# Спочатку копіюємо лише файл із залежностями. 
# Це потрібно для кешування: Docker не буде перевстановлювати бібліотеки, 
# якщо ви змінили лише код, а не список бібліотек.
COPY requirements.txt .

# Встановлюємо залежності
RUN pip install --no-cache-dir -r requirements.txt

# Копіюємо решту коду бекенду
COPY . .

# Відкриваємо порт, на якому працюватиме додаток (стандартно 8080)
EXPOSE 8080

# Команда для запуску сервера при старті контейнера
CMD ["python", "main.py"]